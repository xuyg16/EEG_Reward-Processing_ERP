@article{heydari_reward_2016,
	title = {Reward positivity: {Reward} prediction error or salience prediction error?},
	volume = {53},
	issn = {1469-8986},
	shorttitle = {Reward positivity},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/psyp.12673},
	doi = {10.1111/psyp.12673},
	abstract = {The reward positivity is a component of the human ERP elicited by feedback stimuli in trial-and-error learning and guessing tasks. A prominent theory holds that the reward positivity reflects a reward prediction error signal that is sensitive to outcome valence, being larger for unexpected positive events relative to unexpected negative events (Holroyd \& Coles, 2002). Although the theory has found substantial empirical support, most of these studies have utilized either monetary or performance feedback to test the hypothesis. However, in apparent contradiction to the theory, a recent study found that unexpected physical punishments also elicit the reward positivity (Talmi, Atkinson, \& El-Deredy, 2013). The authors of this report argued that the reward positivity reflects a salience prediction error rather than a reward prediction error. To investigate this finding further, in the present study participants navigated a virtual T maze and received feedback on each trial under two conditions. In a reward condition, the feedback indicated that they would either receive a monetary reward or not and in a punishment condition the feedback indicated that they would receive a small shock or not. We found that the feedback stimuli elicited a typical reward positivity in the reward condition and an apparently delayed reward positivity in the punishment condition. Importantly, this signal was more positive to the stimuli that predicted the omission of a possible punishment relative to stimuli that predicted a forthcoming punishment, which is inconsistent with the salience hypothesis.},
	language = {en},
	number = {8},
	urldate = {2026-03-31},
	journal = {Psychophysiology},
	author = {Heydari, Sepideh and Holroyd, Clay B.},
	year = {2016},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/psyp.12673},
	keywords = {EEG, Reinforcement learning, Reward positivity, Reward prediction error, Salience prediction error},
	pages = {1185--1192},
	file = {Full Text PDF:/Users/xuyg/Zotero/storage/3BTLVBBZ/Heydari and Holroyd - 2016 - Reward positivity Reward prediction error or salience prediction error.pdf:application/pdf},
}

@article{proudfit_reward_2015,
	title = {The reward positivity: {From} basic research on reward to a biomarker for depression},
	volume = {52},
	issn = {1469-8986},
	shorttitle = {The reward positivity},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/psyp.12370},
	doi = {10.1111/psyp.12370},
	abstract = {Feedback indicating monetary loss elicits an apparent negative deflection in the event-related potential (ERP) that has been referred to as the feedback error-related negativity, medial frontal negativity, feedback-related negativity, and feedback negativity—all conceptualizations that suggest a negative ERP component that is greater for loss than gain. In the current paper, I review a programmatic line of research indicating that this apparent negativity actually reflects a reward-related positivity (RewP) that is absent or suppressed following nonreward. I situate the RewP within a broader nomological network of reward processing and individual differences in sensitivity to rewards. Further, I review work linking reductions in the RewP to increased depressive symptoms and risk for depression. Finally, I discuss future directions for research on the RewP.},
	language = {en},
	number = {4},
	urldate = {2026-03-31},
	journal = {Psychophysiology},
	author = {Proudfit, Greg Hajcak},
	year = {2015},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/psyp.12370},
	keywords = {EEG/ERP, Emotion, Feedback negativity, Individual differences, Motivation, Psychopathology, Reward positivity},
	pages = {449--459},
	file = {Full Text PDF:/Users/xuyg/Zotero/storage/F5RDUPPZ/Proudfit - 2015 - The reward positivity From basic research on reward to a biomarker for depression.pdf:application/pdf;Snapshot:/Users/xuyg/Zotero/storage/QFGJA4TJ/psyp.html:text/html},
}

